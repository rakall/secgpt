# pentest-agent Docker Environment Configuration
# Copy this file to .env and fill in your credentials

# Active LLM Provider: local, openai, anthropic, google, groq
ACTIVE_PROVIDER=local

# API Keys (only required if using external providers)
OPENAI_API_KEY=sk-your-api-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here
GOOGLE_API_KEY=your-google-key-here
GROQ_API_KEY=your-groq-key-here

# LLM Model Name (depends on provider)
# Examples: gpt-4-turbo, claude-opus-4, gemini-pro
LLM_MODEL=gpt-4-turbo

# Optional: Custom paths (usually not needed, uses defaults)
# CONFIG_DIR=/app/config
# DATA_DIR=/app/data
